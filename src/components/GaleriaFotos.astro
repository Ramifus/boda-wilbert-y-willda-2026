---
// GaleriaFotos.astro
---

<section id="galeria-fotos" class="relative w-full py-10 px-4">
    <!-- SEPARADOR -->
    <img
        src="/imagenes/separador.png"
        alt=""
        aria-hidden="true"
        class="mx-auto mb-6 w-48"
    />

    <!-- TÍTULO -->
    <p
        class="font-romantic text-3xl text-[#B8960C] text-center mb-6 leading-none"
    >
        Nosotros
    </p>

    <!-- CUADRÍCULA 2 COLUMNAS -->
    <div class="grid grid-cols-2 gap-3 max-w-sm mx-auto">
        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto1.webp"
                alt="Foto 1"
                class="w-full h-44 object-cover"
            />
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto2.webp"
                alt="Foto 2"
                class="w-full h-44 object-cover"
            />
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto3.webp"
                alt="Foto 3"
                class="w-full h-44 object-cover"
            />
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto4.webp"
                alt="Foto 4"
                class="w-full h-44 object-cover"
            />
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto5.webp"
                alt="Foto 5"
                class="w-full h-44 object-cover"
            />
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto6.webp"
                alt="Foto 6"
                class="w-full h-44 object-cover"
            />
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto7.webp"
                alt="Foto 7"
                class="w-full h-44 object-cover"
            />
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
            <img
                src="/imagenes/foto8.webp"
                alt="Foto 8"
                class="w-full h-44 object-cover"
            />
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            "#galeria-fotos",
            { opacity: 0, y: 30 },
            {
                opacity: 1,
                y: 0,
                duration: 1.3,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#galeria-fotos",
                    start: "top 82%",
                    toggleActions: "play none none reset",
                },
            },
        );
    });
</script>
