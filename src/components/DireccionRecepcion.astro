---
// DireccionRecepcion.astro
---

<section id="direccion-recepcion" class="relative w-full py-10 px-6">
    <div class="flex flex-col gap-6 max-w-xs mx-auto">

        <!-- CARD RECEPCIÓN SOCIAL -->
        <div
            id="card-recepcion"
            class="bg-white rounded-3xl shadow-lg p-6 text-center"
        >
            <img
                src="/imagenes/recepcion.png"
                alt="Recepción"
                class="w-14 h-14 mx-auto icono-salvia"
            />

            <p
                class="font-romantic text-[1.75rem] text-[#6B8A52] leading-snug mt-2"
            >
                Recepción Social
            </p>

            <p
                class="font-charm font-bold text-3xl text-[#B8960C] mt-2 leading-none"
            >
                16:00
            </p>

            <p
                class="font-cormorant uppercase text-base text-[#5C6E48] mt-3 leading-relaxed tracking-[0.1em]"
            >
                Salón de eventos<br />"Canciller"
            </p>

            <a
                href="https://maps.app.goo.gl/xxbYAs471b4dhP4x7"
                target="_blank"
                rel="noopener noreferrer"
                class="block mt-5 py-2 px-6 rounded-full font-cormorant uppercase text-xs tracking-widest text-white bg-[#6B8A52] hover:opacity-80 transition-opacity"
            >
                Ver Ubicación
            </a>
        </div>

    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            "#card-recepcion",
            { opacity: 0, y: 30 },
            {
                opacity: 1,
                y: 0,
                duration: 1.2,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#direccion-recepcion",
                    start: "top 82%",
                    toggleActions: "play none none reset",
                },
            },
        );
    });
</script>

<style>
    .icono-salvia {
        filter: invert(47%) sepia(20%) saturate(600%) hue-rotate(75deg)
            brightness(88%);
    }
</style>
