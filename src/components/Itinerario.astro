---
// Itinerario.astro
---

<section
    id="itinerario"
    class="relative w-full py-10 px-6 overflow-hidden isolate"
>
    <!-- FLOR DECORATIVA IZQUIERDA -->
    <img
        src="/imagenes/florcostado.png"
        alt=""
        aria-hidden="true"
        class="absolute top-1/2 left-0 w-40 pointer-events-none select-none opacity-30 -translate-y-1/2 z-[-1]"
    />

    <!-- TÍTULO -->
    <p
        class="font-romantic text-3xl text-[#6B8A52] text-center mb-10 leading-none"
    >
        Itinerario
    </p>

    <!-- TIMELINE GRID -->
    <div class="relative max-w-sm mx-auto">
        <!-- Línea vertical central -->
        <div
            class="absolute left-1/2 top-0 bottom-0 -translate-x-1/2"
            style="border-left: 1.5px dashed rgba(196,168,74,0.5);"
        >
        </div>

        <div class="grid grid-cols-2">
            <!-- ── FILA 1 ── -->
            <div class="flex flex-col items-center text-center pr-3 pb-2">
                <img
                    src="/imagenes/iglesia.png"
                    class="w-12 h-12 icono-salvia"
                />
                <p
                    class="font-cormorant uppercase text-sm text-[#4A6035] mt-2 leading-tight"
                >
                    Ceremonia<br />Religiosa
                </p>
                <p
                    class="font-charm font-bold text-lg text-[#B8960C] mt-1 leading-none"
                >
                    10:30 Hrs.
                </p>
                <div
                    class="w-full border-t border-dashed border-[#c4a84a] opacity-50 mt-2"
                >
                </div>
            </div>
            <div class="flex flex-col items-center text-center pl-3 pb-2 pt-8">
                <img
                    src="/imagenes/recepcion.png"
                    class="w-12 h-12 icono-salvia"
                />
                <p
                    class="font-cormorant uppercase text-sm text-[#4A6035] mt-2 leading-tight"
                >
                    Recepción<br />Social
                </p>
                <p
                    class="font-charm font-bold text-lg text-[#B8960C] mt-1 leading-none"
                >
                    16:00 Hrs.
                </p>
                <div
                    class="w-full border-t border-dashed border-[#c4a84a] opacity-50 mt-auto"
                >
                </div>
            </div>

            <!-- ── FILA 2 ── -->
            <div class="flex flex-col items-center text-center pr-3 pb-2 pt-3">
                <img
                    src="/imagenes/brindis.png"
                    class="w-12 h-12 icono-salvia"
                />
                <p
                    class="font-cormorant uppercase text-sm text-[#4A6035] mt-2 leading-tight"
                >
                    Brindis<br />y Vals
                </p>
                <p
                    class="font-charm font-bold text-lg text-[#B8960C] mt-1 leading-none"
                >
                    16:30 Hrs.
                </p>
                <div
                    class="w-full border-t border-dashed border-[#c4a84a] opacity-50 mt-2"
                >
                </div>
            </div>
            <div class="flex flex-col items-center text-center pl-3 pb-2 pt-8">
                <img src="/imagenes/cena.png" class="w-12 h-12 icono-salvia" />
                <p
                    class="font-cormorant uppercase text-sm text-[#4A6035] mt-2 leading-tight"
                >
                    Cena
                </p>
                <p
                    class="font-charm font-bold text-lg text-[#B8960C] mt-1 leading-none"
                >
                    19:00 Hrs.
                </p>
                <div
                    class="w-full border-t border-dashed border-[#c4a84a] opacity-50 mt-auto"
                >
                </div>
            </div>

            <!-- ── FILA 3 ── -->
            <div class="flex flex-col items-center text-center pr-3 pb-2 pt-3">
                <img src="/imagenes/ramo.png" class="w-12 h-12 icono-salvia" />
                <p
                    class="font-cormorant uppercase text-sm text-[#4A6035] mt-2 leading-tight"
                >
                    Bouquet
                </p>
                <p
                    class="font-charm font-bold text-lg text-[#B8960C] mt-1 leading-none"
                >
                    19:30 Hrs.
                </p>
                <div
                    class="w-full border-t border-dashed border-[#c4a84a] opacity-50 mt-2"
                >
                </div>
            </div>
            <div class="flex flex-col items-center text-center pl-3 pb-2 pt-8">
                <img src="/imagenes/torta.png" class="w-12 h-12 icono-salvia" />
                <p
                    class="font-cormorant uppercase text-sm text-[#4A6035] mt-2 leading-tight"
                >
                    Partimos<br />la Torta
                </p>
                <p
                    class="font-charm font-bold text-lg text-[#B8960C] mt-1 leading-none"
                >
                    20:30 Hrs.
                </p>
                <div
                    class="w-full border-t border-dashed border-[#c4a84a] opacity-50 mt-auto"
                >
                </div>
            </div>

            <!-- ── FILA 4 ── -->
            <div class="flex flex-col items-center text-center pr-3 pt-3">
                <img
                    src="/imagenes/bailando.png"
                    class="w-12 h-12 icono-salvia"
                />
                <p
                    class="font-cormorant uppercase text-sm text-[#4A6035] mt-2 leading-tight"
                >
                    El comienzo<br />de todo
                </p>
                <p
                    class="font-charm font-bold text-lg text-[#B8960C] mt-1 leading-none"
                >
                    22:00 Hrs.
                </p>
            </div>
            <div></div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            "#itinerario",
            { opacity: 0, y: 30 },
            {
                opacity: 1,
                y: 0,
                duration: 1.3,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#itinerario",
                    start: "top 82%",
                    toggleActions: "play none none reset",
                },
            },
        );
    });
</script>

<style>
    .icono-salvia {
        filter: invert(47%) sepia(20%) saturate(600%) hue-rotate(75deg)
            brightness(88%);
    }
</style>
