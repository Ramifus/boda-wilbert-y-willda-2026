---
// NombresFlores.astro
---

<section id="seccion-nombres" class="relative w-full overflow-hidden">

    <!-- FLOR DECORATIVA DERECHA -->
    <img
        src="/imagenes/florcostado.png"
        alt=""
        aria-hidden="true"
        class="absolute top-1/2 right-0 w-40 pointer-events-none select-none opacity-30 scale-x-[-1] -translate-y-1/2 z-[-1]"
    />
    <!-- FOTO PRINCIPAL DE LOS NOVIOS -->
    <div id="foto-container" class="relative w-full overflow-hidden h-[62vh]">
        <img
            id="foto-novios"
            src="/imagenes/principal2.webp"
            alt="Wilbert y Yillda"
            class="absolute inset-0 w-full h-full object-cover object-top"
        />

        <!-- WATER WAVE - 3 capas desfasadas efecto mar -->
        <div class="absolute bottom-0 left-0 w-full z-10" style="height: 36px;">
            <!-- Capa 3 — fase 90°: empieza en cresta, muy transparente -->
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 1440 22"
                preserveAspectRatio="none"
                class="absolute left-0 w-full"
                style="bottom: 16px; height: 22px;"
            >
                <path
                    d="M0,5 C60,5 120,17 180,17 C240,17 300,5 360,5 C420,5 480,17 540,17 C600,17 660,5 720,5 C780,5 840,17 900,17 C960,17 1020,5 1080,5 C1140,5 1200,17 1260,17 C1320,17 1380,5 1440,5 L1440,22 L0,22 Z"
                    fill="rgba(244,240,230,0.28)"
                />
            </svg>

            <!-- Capa 2 — fase 180°: invertida respecto a la sólida, semitransparente -->
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 1440 22"
                preserveAspectRatio="none"
                class="absolute left-0 w-full"
                style="bottom: 7px; height: 22px;"
            >
                <path
                    d="M0,11 C60,17 120,17 180,11 C240,5 300,5 360,11 C420,17 480,17 540,11 C600,5 660,5 720,11 C780,17 840,17 900,11 C960,5 1020,5 1080,11 C1140,17 1200,17 1260,11 C1320,5 1380,5 1440,11 L1440,22 L0,22 Z"
                    fill="rgba(244,240,230,0.62)"
                />
            </svg>

            <!-- Capa 1 — fase 0°: sólida, más baja -->
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 1440 22"
                preserveAspectRatio="none"
                class="absolute bottom-0 left-0 w-full"
                style="height: 22px;"
            >
                <path
                    d="M0,11 C60,5 120,5 180,11 C240,17 300,17 360,11 C420,5 480,5 540,11 C600,17 660,17 720,11 C780,5 840,5 900,11 C960,17 1020,17 1080,11 C1140,5 1200,5 1260,11 C1320,17 1380,17 1440,11 L1440,22 L0,22 Z"
                    fill="#f4f0e6"
                />
            </svg>
        </div>
    </div>

    <!-- TEXTO: ¡NOS CASAMOS! + NOMBRES + ANILLOS -->
    <div
        id="texto-nombres"
        class="text-center px-6 pt-5 pb-2 flex flex-col items-center"
    >
        <p
            class="font-cormorant uppercase tracking-[0.35em] text-sm font-semibold"
            style="color: #B8960C;"
        >
            ¡NOS CASAMOS!
        </p>

        <h2
            class="font-romantic mt-7 leading-tight whitespace-nowrap"
            style="color: #6B8A52; font-size: 2.1rem;"
        >
            Wilbert y Yillda
        </h2>

        <!-- Imagen anillo con filtro verde salvia -->
        <img
            src="/imagenes/anillo.png"
            alt="Anillos de boda"
            class="w-12 mt-5 mx-auto anillo-salvia"
        />
    </div>
</section>

<!-- BOTÓN FLOTANTE PLAY/PAUSE -->
<button
    id="btn-audio-control"
    aria-label="Controlar música"
    class="fixed bottom-6 right-6 z-[9999] w-12 h-12 rounded-full shadow-lg
           flex items-center justify-center
           transition-all duration-300 hover:scale-110 active:scale-95"
    style="opacity: 0; pointer-events: none; background-color: #f4f0e6; border: 1.5px solid #4A6035;"
>
    <svg
        id="icono-pause"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="#4A6035"
    >
        <rect x="6" y="4" width="4" height="16" rx="1"></rect>
        <rect x="14" y="4" width="4" height="16" rx="1"></rect>
    </svg>
    <svg
        id="icono-play"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 hidden"
        viewBox="0 0 24 24"
        fill="#4A6035"
    >
        <path d="M8 5v14l11-7z"></path>
    </svg>
</button>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // FOTO - aparece con leve zoom out
        gsap.fromTo(
            "#foto-novios",
            { opacity: 0, scale: 1.06 },
            {
                opacity: 1,
                scale: 1,
                duration: 1.5,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#foto-container",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );

        // TEXTO - sube suavemente
        gsap.fromTo(
            "#texto-nombres",
            { opacity: 0, y: 28 },
            {
                opacity: 1,
                y: 0,
                duration: 1.2,
                ease: "power2.out",
                delay: 0.4,
                scrollTrigger: {
                    trigger: "#texto-nombres",
                    start: "top 92%",
                    toggleActions: "play none none reset",
                },
            },
        );

        // BOTÓN FLOTANTE PLAY/PAUSE
        const btnAudio = document.getElementById(
            "btn-audio-control",
        ) as HTMLButtonElement;
        const iconoPlay = document.getElementById("icono-play");
        const iconoPause = document.getElementById("icono-pause");

        const intervalo = setInterval(() => {
            const audio = (window as any).audioGlobal;
            if (audio) {
                clearInterval(intervalo);
                gsap.to(btnAudio, {
                    opacity: 1,
                    duration: 0.5,
                    ease: "power2.out",
                    onStart: () => {
                        btnAudio.style.pointerEvents = "auto";
                    },
                });
                iconoPlay?.classList.add("hidden");
                iconoPause?.classList.remove("hidden");

                btnAudio.addEventListener("click", () => {
                    const audioActual = (window as any).audioGlobal;
                    const reproduciendo = (window as any)
                        .estaReproduciendoGlobal;
                    if (!audioActual) return;
                    if (reproduciendo) {
                        audioActual.pause();
                        (window as any).estaReproduciendoGlobal = false;
                        iconoPause?.classList.add("hidden");
                        iconoPlay?.classList.remove("hidden");
                    } else {
                        audioActual.play();
                        (window as any).estaReproduciendoGlobal = true;
                        iconoPlay?.classList.add("hidden");
                        iconoPause?.classList.remove("hidden");
                    }
                    gsap.fromTo(
                        btnAudio,
                        { scale: 0.85 },
                        { scale: 1, duration: 0.3, ease: "back.out(2)" },
                    );
                });
            }
        }, 300);
    });
</script>

<style>
    /* Filtro para colorizar el icono de anillos en dorado #B8960C */
    .anillo-salvia {
        filter: invert(55%) sepia(75%) saturate(650%) hue-rotate(5deg) brightness(88%);
    }
</style>
