---
// SugerenciaRegalos.astro
---

<section
    id="sugerencia-regalos"
    class="relative w-full py-10 px-6 text-center overflow-hidden isolate"
>
    <!-- FLOR DECORATIVA IZQUIERDA -->
    <img
        src="/imagenes/florcostado.png"
        alt=""
        aria-hidden="true"
        class="absolute top-1/2 left-0 w-40 pointer-events-none select-none opacity-30 -translate-y-1/2 z-[-1]"
    />
    <!-- TÍTULO -->
    <p class="font-romantic text-3xl text-[#B8960C] leading-snug mb-6">
        Sugerencia de Regalos
    </p>

    <!-- ICONO REGALO -->
    <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 64 64"
        fill="none"
        class="w-14 h-14 mx-auto"
        stroke="#6B8A52"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <!-- Caja del regalo -->
        <rect x="8" y="28" width="48" height="30" rx="3"></rect>
        <!-- Tapa -->
        <rect x="6" y="20" width="52" height="10" rx="3"></rect>
        <!-- Lazo vertical -->
        <line x1="32" y1="20" x2="32" y2="58"></line>
        <!-- Lazo horizontal (tapa) -->
        <line x1="6" y1="25" x2="58" y2="25"></line>
        <!-- Moño izquierdo -->
        <path d="M32,20 C28,14 18,14 20,20 C22,26 32,20 32,20Z"></path>
        <!-- Moño derecho -->
        <path d="M32,20 C36,14 46,14 44,20 C42,26 32,20 32,20Z"></path>
    </svg>

    <!-- TEXTO -->
    <p
        class="font-cormorant italic text-xl text-[#5C6E48] mt-5 leading-relaxed max-w-xs mx-auto"
    >
        Su presencia y sus buenos deseos son nuestro mejor regalo. Si desean
        hacernos llegar algún presente estaremos muy agradecidos. Gracias por tu
        muestra de cariño.
    </p>

    <!-- QR CODE -->
    <div
        id="qr-card"
        class="mt-7 mx-auto bg-white rounded-2xl shadow-md p-5 border border-[#e8e0d0] inline-block"
    >
        <img src="/imagenes/qr.png" alt="Código QR" class="w-44 h-44 mx-auto" />
    </div>

    <!-- DATOS DE CUENTA -->
    <div class="mt-5 flex flex-col items-center gap-1">
        <p class="font-upcil uppercase text-xl text-[#B8960C]">
            Wilbert Vladimir Chura Perez
        </p>
        <p class="font-cormorant text-xl text-[#5C6E48]">
            Número de cuenta:
            <span class="font-cormorant font-semibold text-[#4A6035]"
                >1016766198</span
            >
        </p>
        <p class="font-cormorant italic text-xl text-[#5C6E48]">
            Concepto: Wilbert y Yillda
        </p>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            "#sugerencia-regalos",
            { opacity: 0, y: 28 },
            {
                opacity: 1,
                y: 0,
                duration: 1.3,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#sugerencia-regalos",
                    start: "top 82%",
                    toggleActions: "play none none reset",
                },
            },
        );
    });
</script>
