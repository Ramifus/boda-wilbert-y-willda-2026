---
// FotoFinal.astro
---

<section id="foto-final" class="relative w-full overflow-hidden">

    <!-- FOTO -->
    <img
        id="foto-final-img"
        src="/imagenes/principal3.webp"
        alt="Wilbert y Yillda"
        class="w-full h-auto object-cover object-top"
    />

    <!-- WATER WAVE ARRIBA — 3 capas desfasadas (igual que NombresFlores) -->
    <div class="absolute top-0 left-0 w-full z-10" style="height: 36px;">

        <!-- Capa 3 — fase 90°, muy transparente -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 22"
            preserveAspectRatio="none" class="absolute left-0 w-full"
            style="top: 16px; height: 22px;">
            <path
                d="M0,5 C60,5 120,17 180,17 C240,17 300,5 360,5 C420,5 480,17 540,17 C600,17 660,5 720,5 C780,5 840,17 900,17 C960,17 1020,5 1080,5 C1140,5 1200,17 1260,17 C1320,17 1380,5 1440,5 L1440,0 L0,0 Z"
                fill="rgba(255,255,255,0.28)"
            />
        </svg>

        <!-- Capa 2 — fase 180°, semitransparente -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 22"
            preserveAspectRatio="none" class="absolute left-0 w-full"
            style="top: 8px; height: 22px;">
            <path
                d="M0,11 C60,17 120,17 180,11 C240,5 300,5 360,11 C420,17 480,17 540,11 C600,5 660,5 720,11 C780,17 840,17 900,11 C960,5 1020,5 1080,11 C1140,17 1200,17 1260,11 C1320,5 1380,5 1440,11 L1440,0 L0,0 Z"
                fill="rgba(255,255,255,0.62)"
            />
        </svg>

        <!-- Capa 1 — fase 0°, sólida -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 22"
            preserveAspectRatio="none" class="absolute top-0 left-0 w-full"
            style="height: 22px;">
            <path
                d="M0,11 C60,5 120,5 180,11 C240,17 300,17 360,11 C420,5 480,5 540,11 C600,17 660,17 720,11 C780,5 840,5 900,11 C960,17 1020,17 1080,11 C1140,5 1200,5 1260,11 C1320,17 1380,17 1440,11 L1440,0 L0,0 Z"
                fill="#ffffff"
            />
        </svg>

    </div>

</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            "#foto-final-img",
            { opacity: 0, scale: 1.04 },
            {
                opacity: 1,
                scale: 1,
                duration: 1.5,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#foto-final",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );
    });
</script>
